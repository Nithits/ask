RewriteEngine On

# เพิ่มบรรทัดนี้: ถ้าเป็น POST ให้ข้ามกฎการ Redirect 301 ไปเลย (เพื่อรักษาข้อมูล)
RewriteCond %{REQUEST_METHOD} POST [NC]
RewriteRule ^ - [S=1]

# กฎเดิมของคุณ: ถ้าเรียก .php ให้ Redirect 301 (จะมีผลเฉพาะ GET)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# ถ้าพิมพ์มาแบบไม่มีนามสกุล ให้แอบไปเรียกไฟล์ .php มาโชว์ (Internal Rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

